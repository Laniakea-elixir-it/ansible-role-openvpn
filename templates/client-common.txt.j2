client
dev tun
proto {{ openvpn_protocol }}
remote {{ server_ip }} {{ openvpn_port }}
resolv-retry infinite
nobind
persist-key
persist-tun
remote-cert-tls server
auth SHA512
ignore-unknown-option block-outside-dns
block-outside-dns
verb 3
auth-user-pass
reneg-sec {{ openvpn_reneg_sec }}
hand-window {{ openvpn_hand_window }}
route-nopull
route {{ openvpn_tenant_network }} {{ openvpn_tenant_netmask }}
